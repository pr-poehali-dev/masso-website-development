{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET health check",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "POST without body returns error",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "POST with missing password",
      "method": "POST",
      "path": "/",
      "body": {"email": "admin@massopro.ru"},
      "expectedStatus": 400
    },
    {
      "name": "POST with wrong credentials",
      "method": "POST",
      "path": "/",
      "body": {"email": "wrong@example.com", "password": "wrongpass"},
      "expectedStatus": 401
    }
  ]
}
