      "method": "POST",
      "path": "/",
      "body": {"phone": "+71234567890"},
      "expectedStatus": 400
    },
    {
      "name": "PUT update lead without id",
      "method": "PUT",
      "path": "/",
      "body": {"name": "Test"},
      "expectedStatus": 400
    }
  ]
}
