{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET leads list",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET leads with status filter",
      "method": "GET",
      "path": "/?status=new",
      "expectedStatus": 200
    },
    {
